# Local SQLite database (Prisma).
# Only needed for local dev to persist contact-form submissions.
# On Vercel/serverless, the contact form falls back to a mailto: link if the
# database is unavailable — so this variable is optional in production.
# For persistent storage on Vercel, swap this for a hosted DB (e.g. Neon,
# Supabase, PlanetScale) and update prisma/schema.prisma's provider accordingly.
DATABASE_URL="file:./dev.db"
